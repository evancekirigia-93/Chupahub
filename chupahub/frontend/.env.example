NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use either the legacy anon key or the newer publishable key from Supabase.
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-your-supabase-publishable-key

# Server-side API/route handler variables. Do not commit real credentials.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=replace-with-your-supabase-publishable-key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
