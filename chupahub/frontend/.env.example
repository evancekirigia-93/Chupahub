NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use either the legacy anon key or the newer publishable key from Supabase.
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-your-supabase-publishable-key

# Server-side API/route handler variables. Do not commit real credentials.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=replace-with-your-supabase-publishable-key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key

# Daraja M-Pesa Express (server-side only). Set MPESA_ENVIRONMENT=sandbox first.
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback
MPESA_ENVIRONMENT=sandbox

# Optional notification providers (server-side only; no credentials are faked).
RESEND_API_KEY=
EMAIL_FROM=
ADMIN_NOTIFICATION_EMAIL=evancekirigia@gmail.com # set this securely in Vercel, not in Git
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
ADMIN_NOTIFICATION_PHONE=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ADMIN_NUMBER=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
